<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <PreferenceCategory android:title="@string/preference_category_header_logging">

        <SwitchPreference
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:defaultValue="false"
            android:key="@string/pref_key_logs"
            android:title="@string/use_logs"
            app:summary="@string/use_logs_summary" />

        <EditTextPreference
            android:key="@string/pref_key_log_upload_url"
            android:title="@string/pref_log_upload_url_title"
            android:defaultValue="https://example.com"
            app:useSimpleSummaryProvider="true" />

        <EditTextPreference
            android:key="@string/pref_key_log_upload_username"
            android:title="@string/pref_log_upload_user_title"
            android:defaultValue=""
            app:useSimpleSummaryProvider="true" />

        <EditTextPreference
            android:key="@string/pref_key_log_upload_password"
            android:title="@string/pref_log_upload_pass_title"
            android:defaultValue=""
            android:inputType="textPassword"
            app:useSimpleSummaryProvider="false" />

        <de.felixnuesse.extract.settings.preferences.ButtonPreference
            android:key="pref_key_export_logs"
            android:title="@string/export_logs"
            />

        <de.felixnuesse.extract.settings.preferences.ButtonPreference
            android:key="pref_key_clear_logs"
            android:title="@string/clear_logs" />
    </PreferenceCategory>

    <PreferenceCategory android:title="@string/preference_category_header_rclone">

        <de.felixnuesse.extract.settings.preferences.ButtonPreference
            android:title="@string/pref_send_sigquit_title"
            app:summary="@string/pref_send_sigquit_summary"
            android:key="TempKeySigquit" />
    </PreferenceCategory>
</PreferenceScreen>